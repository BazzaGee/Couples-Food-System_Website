---
import BaseLayout from '../../layouts/BaseLayout.astro';
import features from '../../data/features.json';
import Waitlist from '../../components/sections/Waitlist.astro';
import WaitlistForm from '../../components/forms/WaitlistForm.astro';
---

<BaseLayout title="Features | Couples Food System" description="Discover how our intuitive features make planning, shopping, and cooking together a breeze." version="v1">
  <section class="py-20 max-w-6xl mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h1 class="text-4xl md:text-5xl font-semibold text-text-primary tracking-tight mb-6">Designed for "We", not "You"</h1>
      <p class="text-xl text-text-secondary">Discover how our intuitive features make planning, shopping, and cooking together a breeze.</p>
    </div>

    <div class="space-y-8">
      {features.features.map((feature, index) => (
        <div class={`bg-white rounded-2xl border border-border p-8 md:p-12 flex flex-col md:flex-row gap-8 items-center shadow-sm ${index % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
          <div class="flex-1">
            <h2 class="text-3xl font-semibold mb-4 tracking-tight flex items-center gap-3">
              {feature.title}
              {feature.badge && (
                <span class={feature.badgeType === 'primary' ? 'badge-signature' : 'badge-unique'}>
                  {feature.badge}
                </span>
              )}
            </h2>
            <p class="text-lg text-text-secondary mb-6">{feature.shortDescription}</p>
            <a href={feature.href} class="text-sage font-medium hover:text-sage-dark inline-flex items-center gap-1">
              Learn more &rarr;
            </a>
          </div>
          <div class="flex-1 w-full rounded-xl aspect-video overflow-hidden border border-border">
            <img src={`/images/v1/screenshot-${feature.id === 'adaptive-cooking' ? 'adaptive' : feature.id === 'shared-grocery-list' ? 'shopping' : feature.id === 'pantry-ai' ? 'pantry' : 'mealplan'}.webp`} alt="{feature.title} app interface" class="w-full h-full object-cover" decoding="async" />
          </div>
        </div>
      ))}
    </div>
  </section>

  <Waitlist>
    <WaitlistForm />
  </Waitlist>
</BaseLayout>

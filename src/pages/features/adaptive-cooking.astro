---
import BaseLayout from '../../layouts/BaseLayout.astro';
import features from '../../data/features.json';
import Waitlist from '../../components/sections/Waitlist.astro';
import WaitlistForm from '../../components/forms/WaitlistForm.astro';

const feature = features.features.find(f => f.id === 'adaptive-cooking')!;
---

<BaseLayout title="Adaptive Shared Cooking | Couples Food System" description="One cooking session, two different plates. AI-adapted plating instructions so you both hit your unique goals." version="v1">
  <section class="py-20 max-w-4xl mx-auto px-6">
    <a href="/features" class="text-sage hover:text-sage-dark mb-8 inline-block font-medium">&larr; Back to all features</a>
    <div class="bg-white rounded-2xl border border-border p-8 md:p-16 shadow-sm">
      <span class="badge-signature mb-6 inline-block">The Couples Food System Advantage</span>
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight mb-6">{feature.title}</h1>
      <p class="text-xl text-text-secondary leading-relaxed mb-10">{feature.longDescription}</p>

      <div class="rounded-xl aspect-video w-full overflow-hidden border border-border mb-10">
        <img src="/images/screenshots/screenshot-adaptive.webp" alt="Adaptive cooking infographic: one pan splits into two plates - 450 cal plate with more vegetables and 700 cal plate with more protein" class="w-full h-full object-cover" loading="lazy" />
      </div>

      <div class="bg-cream-dark rounded-xl p-8 border border-border mb-10">
        <h3 class="text-xl font-semibold text-text-primary mb-6">The Adaptive Plating Example</h3>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-border">
            <p class="font-semibold text-text-primary mb-2">{feature.example.partnerA.name}</p>
            <p class="text-sm text-text-secondary mb-1">Goal: {feature.example.partnerA.goal}</p>
            <p class="text-sm text-text-secondary mb-3">~{feature.example.partnerA.calories} cal</p>
            <p class="text-text-primary">{feature.example.partnerA.plate}</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-border">
            <p class="font-semibold text-text-primary mb-2">{feature.example.partnerB.name}</p>
            <p class="text-sm text-text-secondary mb-1">Goal: {feature.example.partnerB.goal}</p>
            <p class="text-sm text-text-secondary mb-3">~{feature.example.partnerB.calories} cal</p>
            <p class="text-text-primary">{feature.example.partnerB.plate}</p>
          </div>
        </div>
        <p class="text-center text-text-secondary mt-6 font-medium">Same stir-fry. Same pan. Different plates.</p>
      </div>

      <div class="text-lg text-text-secondary space-y-6">
        <p>
          When you share a life, you share meals. But traditional meal planning apps treat everyone as an isolated individual. They expect you to either abandon your goals to eat the same thing, or cook completely separate dinners.
        </p>
        <p>
          <strong>We solved this.</strong> You follow one single cooking workflow together. When the food is ready, the app provides visual, AI-adapted plating guides. It tells you exactly how much chicken to give Partner A, and how much extra rice to give Partner B.
        </p>
        <p>
          It eliminates friction, reduces dishes, and brings the joy back to a shared kitchen.
        </p>
      </div>

      <ul class="mt-10 space-y-3">
        {feature.benefits.map((benefit) => (
          <li class="flex items-start gap-3 text-lg text-text-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sage w-6 h-6 flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
            {benefit}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <Waitlist>
    <WaitlistForm />
  </Waitlist>
</BaseLayout>

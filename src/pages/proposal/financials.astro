---
import SpokeLayout from '../../layouts/SpokeLayout.astro';
import RevenueChart from '../../components/pitch/RevenueChart.astro';
import RolloutTimeline from '../../components/pitch/RolloutTimeline.astro';
import marketData from '../../data/pitch/market-data.json';
import financials from '../../data/pitch/financials.json';
---

<SpokeLayout
  title="Financials & Strategy — CUPLA Proposal"
  description="Revenue projections, full cost structure, unit economics, break-even analysis, pricing strategy, go-to-market channels, and KPIs by phase."
>
  <!-- HERO -->
  <section class="pt-20 md:pt-28 pb-16 px-6">
    <div class="max-w-4xl mx-auto">
      <span class="text-xs text-text-secondary font-medium uppercase tracking-wider">Financials & Strategy</span>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mt-3 mb-6">Path to $1M ARR<br/>in Under 3 Years</h1>
      <p class="text-lg text-text-secondary leading-relaxed max-w-2xl">
        Conservative projections based on organic growth only. Per-household pricing (not per-person) reinforces the "we" framing and makes the premium decision a joint one. Below the cost of one takeout meal — positioned as a no-brainer for couples who eat at home 4+ nights per week. Infrastructure costs $0 at launch. The only variable cost is AI tokens.
      </p>
    </div>
  </section>

  <!-- REVENUE PROJECTIONS -->
  <section class="spoke-section-alt">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="proposal-section-title text-center mb-4">Revenue Projections</h2>
      <p class="text-center text-text-secondary mb-8">Conservative estimates · 10% premium conversion · $10/mo per household · Organic growth only</p>
      <RevenueChart />
      <div class="overflow-x-auto mt-8 max-w-3xl mx-auto">
        <table class="comparison-table w-full">
          <thead>
            <tr>
              <th class="rounded-tl-xl">Timeline</th>
              <th>Households</th>
              <th>Premium</th>
              <th>Premium HH</th>
              <th>Monthly Revenue</th>
              <th class="rounded-tr-xl">Annual Revenue</th>
            </tr>
          </thead>
          <tbody>
            {marketData.revenueProjections.map((rp) => (
              <tr>
                <td class="font-semibold">{rp.timeline}</td>
                <td>{rp.households.toLocaleString()}</td>
                <td>{rp.premiumConversion}</td>
                <td>{rp.premiumHouseholds.toLocaleString()}</td>
                <td>{rp.monthlyRevenue}</td>
                <td>{rp.annualRevenue}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="mt-6 max-w-3xl mx-auto">
        <p class="text-xs text-text-secondary">
          <strong class="text-text-primary">Derivation logic:</strong> 500 households at Month 6 = 0.007% of the SAM (3-5M multi-goal households). This is extremely conservative — it assumes minimal marketing beyond CUPLA's existing channels. Year 1 at 3,000 households = 0.04% of SAM. Year 5 at 200,000 households = 2.7% of SAM. All figures assume organic growth only — no paid advertising budget.
        </p>
      </div>
    </div>
  </section>

  <!-- FULL COST STRUCTURE / P&L -->
  <section class="spoke-section">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="proposal-section-title mb-6">Full Cost Structure — Where the Money Goes</h2>
      <p class="text-text-secondary mb-6">Revenue is only half the story. Here is the complete cost breakdown at each phase:</p>
      <div class="overflow-x-auto">
        <table class="comparison-table w-full">
          <thead>
            <tr>
              <th class="rounded-tl-xl">Cost Category</th>
              <th>Month 6 (500 HH)</th>
              <th>Year 1 (3,000 HH)</th>
              <th>Year 2 (15,000 HH)</th>
              <th class="rounded-tr-xl">Year 3 (50,000 HH)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="font-semibold">AI API (Anthropic)</td>
              <td class="text-text-secondary text-xs">$15-30/mo</td>
              <td class="text-text-secondary text-xs">$90-180/mo</td>
              <td class="text-text-secondary text-xs">$450-900/mo</td>
              <td class="text-text-secondary text-xs">$1,500-3,000/mo</td>
            </tr>
            <tr>
              <td class="font-semibold">Infrastructure</td>
              <td class="text-sage text-xs font-semibold">~$0 (prototype)</td>
              <td class="text-sage text-xs font-semibold">~$0-5/mo</td>
              <td class="text-text-secondary text-xs">$5-25/mo</td>
              <td class="text-text-secondary text-xs">$25-100/mo</td>
            </tr>
            <tr>
              <td class="font-semibold">Domain + Email</td>
              <td class="text-text-secondary text-xs">$15/mo</td>
              <td class="text-text-secondary text-xs">$15/mo</td>
              <td class="text-text-secondary text-xs">$15/mo</td>
              <td class="text-text-secondary text-xs">$15/mo</td>
            </tr>
            <tr>
              <td class="font-semibold">Developer Time (1 dev)</td>
              <td class="text-text-secondary text-xs">Build phase (sweat equity)</td>
              <td class="text-text-secondary text-xs">Build phase (sweat equity)</td>
              <td class="text-text-secondary text-xs">$5,000-8,000/mo</td>
              <td class="text-text-secondary text-xs">$8,000-12,000/mo</td>
            </tr>
            <tr>
              <td class="font-semibold">Marketing (organic)</td>
              <td class="text-sage text-xs font-semibold">$0</td>
              <td class="text-sage text-xs font-semibold">$0</td>
              <td class="text-text-secondary text-xs">$500-1,000/mo</td>
              <td class="text-text-secondary text-xs">$1,000-2,000/mo</td>
            </tr>
            <tr>
              <td class="font-semibold font-bold">Total Monthly Cost</td>
              <td class="text-text-secondary text-xs font-bold">~$15-45</td>
              <td class="text-text-secondary text-xs font-bold">~$105-200</td>
              <td class="text-text-secondary text-xs font-bold">~$5,970-9,925</td>
              <td class="text-text-secondary text-xs font-bold">~$10,525-17,100</td>
            </tr>
            <tr>
              <td class="font-semibold font-bold">Monthly Revenue</td>
              <td class="text-sage text-xs font-bold">$320-480</td>
              <td class="text-sage text-xs font-bold">$2,400-3,600</td>
              <td class="text-sage text-xs font-bold">$14,400-21,600</td>
              <td class="text-sage text-xs font-bold">$48,000-72,000</td>
            </tr>
            <tr>
              <td class="font-semibold font-bold text-sage-dark">Net Monthly</td>
              <td class="text-sage-dark text-xs font-bold">+$275-435</td>
              <td class="text-sage-dark text-xs font-bold">+$2,200-3,400</td>
              <td class="text-sage-dark text-xs font-bold">+$8,430-11,675</td>
              <td class="text-sage-dark text-xs font-bold">+$37,475-54,900</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="mt-4 pitch-card-sage">
        <p class="text-sm text-text-secondary">
          <strong class="text-sage-dark">Break-even analysis:</strong> The product is profitable from Month 1 at the household level. At the business level, break-even occurs when monthly revenue exceeds developer time + infrastructure. Assuming a single developer at sweat equity during build, break-even occurs at ~500 households (Month 6). If developer time is valued at $5,000/mo, break-even occurs at ~3,000 households (Month 12). <strong class="text-sage-dark">The product is self-sustaining from Year 1.</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- AI COST OVERVIEW -->
  <section class="spoke-section-alt">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="proposal-section-title mb-6">AI Cost Overview</h2>
      <p class="text-text-secondary mb-6">The AI cost is the only meaningful variable cost. Here is how it breaks down:</p>
      <div class="overflow-x-auto">
        <table class="comparison-table w-full">
          <thead>
            <tr>
              <th class="rounded-tl-xl">Scenario</th>
              <th>Cost Per Generation</th>
              <th>Monthly Cost (1 meal/day)</th>
              <th class="rounded-tr-xl">With Caching</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="font-semibold">Single meal plan</td>
              <td>$0.01-0.02</td>
              <td>$0.30-0.60</td>
              <td class="text-sage text-xs font-semibold">$0.15-0.30 (estimated 50% cache hit rate)</td>
            </tr>
            <tr>
              <td class="font-semibold">Daily plan (3 meals)</td>
              <td>$0.03-0.05</td>
              <td>$0.90-1.50</td>
              <td class="text-sage text-xs font-semibold">$0.45-0.75 (estimated 50% cache hit rate)</td>
            </tr>
            <tr>
              <td class="font-semibold">Weekly plan</td>
              <td>$0.08-0.12</td>
              <td>$0.32-0.48/month</td>
              <td class="text-sage text-xs font-semibold">$0.16-0.24 (estimated 50% cache hit rate)</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="mt-4 pitch-card">
        <p class="text-sm text-text-secondary">
          <strong class="text-text-primary">Bottom line:</strong> At $0.01-0.03 per meal generation and 1 generation per household per day, the AI cost is $0.30-0.90 per household per month — well covered by the $10/mo premium price with 85-90% gross margin. Caching reduces token costs by an estimated 40-60%.
        </p>
      </div>
    </div>
  </section>

  <!-- PRICING TIERS -->
  <section class="spoke-section-alt">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="proposal-section-title text-center mb-8">Pricing Tiers</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="pitch-card">
          <div class="flex items-center gap-3 mb-3">
            <span class="bg-sage/10 text-sage text-sm font-bold px-3 py-1 rounded-full">FREE</span>
            <span class="text-2xl font-bold">$0/mo</span>
          </div>
          <ul class="space-y-2 text-sm text-text-secondary mb-4">
            {marketData.pricingTiers[0].features.map((f) => (
              <li class="flex items-start gap-2"><span class="text-sage mt-0.5">✓</span> {f}</li>
            ))}
          </ul>
          <p class="text-xs text-text-secondary bg-cream-dark p-3 rounded-lg border border-border">{marketData.pricingTiers[0].purpose}</p>
        </div>
        <div class="pitch-card border-sage/30 border-2">
          <div class="flex items-center gap-3 mb-3">
            <span class="badge-signature">PREMIUM</span>
            <span class="text-2xl font-bold">$8-12/mo</span>
          </div>
          <ul class="space-y-2 text-sm text-text-secondary mb-4">
            {marketData.pricingTiers[1].features.map((f) => (
              <li class="flex items-start gap-2"><span class="text-sage mt-0.5">✓</span> {f}</li>
            ))}
          </ul>
          <p class="text-xs text-text-secondary bg-cream-dark p-3 rounded-lg border border-border">{marketData.pricingTiers[1].purpose}</p>
        </div>
      </div>
      <div class="mt-6 pitch-card">
        <h3 class="font-bold text-lg mb-3">Competitive Pricing Comparison</h3>
        <div class="overflow-x-auto">
          <table class="comparison-table w-full text-sm">
            <thead>
              <tr>
                <th class="rounded-tl-xl">Competitor</th>
                <th>Price</th>
                <th class="rounded-tr-xl">What You Get</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="font-semibold">Yummo</td>
                <td>$9.99/mo</td>
                <td class="text-text-secondary text-xs">Adaptive portions, AI meals, no collaboration</td>
              </tr>
              <tr>
                <td class="font-semibold">Fitia (Family)</td>
                <td>$89.99/yr ($7.50/mo)</td>
                <td class="text-text-secondary text-xs">Synced plans, 2-6 users, clinical UX</td>
              </tr>
              <tr>
                <td class="font-semibold">PlateMates</td>
                <td>$5.99/mo</td>
                <td class="text-text-secondary text-xs">200+ split recipes, no AI, no sync</td>
              </tr>
              <tr>
                <td class="font-semibold">Eat This Much</td>
                <td>$9.99/mo</td>
                <td class="text-text-secondary text-xs">AI meal plans, single-user only</td>
              </tr>
              <tr>
                <td class="font-semibold">AnyList</td>
                <td>$9.99/yr ($0.83/mo)</td>
                <td class="text-text-secondary text-xs">Shared lists, recipe integration, no AI</td>
              </tr>
              <tr>
                <td class="font-semibold text-sage-dark">CUPLA (Premium)</td>
                <td class="text-sage-dark font-semibold">$8-12/mo</td>
                <td class="text-sage text-xs font-semibold">AI + collaboration + adaptive + pantry + relationship UX</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-xs text-text-secondary mt-3">
          CUPLA's pricing is positioned above free hobby apps and alongside established AI tools. The value proposition (AI + real-time collaboration + adaptive portions + relationship UX) exceeds any single competitor at a comparable price point.
        </p>
      </div>
    </div>
  </section>

  <!-- UNIT ECONOMICS -->
  <section class="spoke-section">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="proposal-section-title text-center mb-8">Unit Economics at Scale</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <div class="stat-card">
          <div class="stat-number text-2xl">{marketData.unitEconomics.premiumPrice}</div>
          <div class="stat-label">Premium Price</div>
        </div>
        <div class="stat-card">
          <div class="stat-number text-2xl">{marketData.unitEconomics.aiCostPerHousehold}</div>
          <div class="stat-label">AI Cost / Household</div>
        </div>
        <div class="stat-card">
          <div class="stat-number text-2xl">{marketData.unitEconomics.grossMargin}</div>
          <div class="stat-label">Gross Margin</div>
        </div>
        <div class="stat-card">
          <div class="stat-number text-2xl">{marketData.unitEconomics.cacOrganic}</div>
          <div class="stat-label">Organic CAC</div>
        </div>
        <div class="stat-card">
          <div class="stat-number text-2xl">{marketData.unitEconomics.cacPaid}</div>
          <div class="stat-label">Paid CAC Target</div>
        </div>
        <div class="stat-card">
          <div class="stat-number text-2xl">{marketData.unitEconomics.infraCostPerHousehold}</div>
          <div class="stat-label">Infra Cost / HH</div>
        </div>
      </div>
      <div class="mt-6 pitch-card">
        <p class="text-sm text-text-secondary">
          <strong class="text-text-primary">Note on CAC:</strong> "Organic CAC = $0" means no paid advertising spend. Organic growth still requires content creation, community management, and social media effort — these are included in the marketing cost line of the P&L. The $0 figure refers specifically to paid acquisition cost per household.
        </p>
      </div>
    </div>
  </section>

  <!-- FINANCIAL SENSITIVITY ANALYSIS -->
  <section class="spoke-section-alt">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="proposal-section-title mb-6">Financial Sensitivity Analysis — What If Things Go Wrong?</h2>
      <p class="text-text-secondary mb-6">Every projection is based on assumptions. Here is how the numbers change under stress scenarios:</p>
      <div class="space-y-4">
        <div class="pitch-card">
          <h3 class="font-bold text-lg mb-2">Scenario A: Premium Conversion Is 5% Instead of 10%</h3>
          <p class="text-sm text-text-secondary mb-2">If only half as many users convert to premium, revenue is cut in half. At Year 1: $1,200-1,800/mo instead of $2,400-3,600/mo. At Year 3: $24,000-36,000/mo instead of $48,000-72,000/mo.</p>
          <p class="text-sm text-sage font-medium">Mitigation: The free tier is designed to lock couples into the ecosystem. Once both partners are active, the premium upgrade (AI meals, adaptive portions) becomes the natural next step. Even at 5% conversion, the product covers its infrastructure costs and remains profitable at the household level.</p>
        </div>
        <div class="pitch-card">
          <h3 class="font-bold text-lg mb-2">Scenario B: AI Costs Triple</h3>
          <p class="text-sm text-text-secondary mb-2">If Anthropic pricing increases 3x, AI cost per household rises from $1.00-1.50/mo to $3.00-4.50/mo. Gross margin drops from 85-90% to 75-80%. Still highly profitable.</p>
          <p class="text-sm text-sage font-medium">Mitigation: AI Gateway caching reduces token usage by 40-60%. Additionally, the product can switch to cheaper models (Claude Haiku instead of Sonnet) for routine meal generation, reserving Sonnet for complex adaptive cooking scenarios.</p>
        </div>
        <div class="pitch-card">
          <h3 class="font-bold text-lg mb-2">Scenario C: Infrastructure Costs Rise Unexpectedly</h3>
          <p class="text-sm text-text-secondary mb-2">If hosting infrastructure costs increase significantly, margins would be affected. At 50,000 households, estimated infrastructure cost is $25-100/mo — still negligible compared to $48,000-72,000/mo in revenue.</p>
          <p class="text-sm text-sage font-medium">Mitigation: The architecture is designed for portability. Infrastructure patterns can be replicated on alternative platforms if needed. At scale, infrastructure costs remain a small fraction of revenue.</p>
        </div>
        <div class="pitch-card">
          <h3 class="font-bold text-lg mb-2">Scenario D: Churn Is Higher Than Expected</h3>
          <p class="text-sm text-text-secondary mb-2">If 40% of users churn in Month 2, the revenue projections change dramatically. The growth curve flattens and the path to $1M ARR extends from Year 3 to Year 4-5.</p>
          <p class="text-sm text-sage font-medium">Mitigation: The free tier is designed to maximize retention by keeping couples engaged even if they do not convert to premium. The viral loop (partner invites) means each household has two users — if one churns, the other may remain. Day-7 retention target of >40% in Phase 1 is the key metric to watch.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- GO-TO-MARKET CHANNELS -->
  <section class="spoke-section">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="proposal-section-title text-center mb-8">Go-to-Market Channels</h2>
      <p class="text-center text-text-secondary mb-6">All organic. All leveraging CUPLA's existing brand and distribution.</p>
      <div class="space-y-3">
        {financials.gtmChannels.map((ch) => (
          <div class="pitch-card">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-semibold text-text-primary">{ch.channel}</h3>
              <span class="text-xs text-text-secondary">{ch.strategy}</span>
            </div>
            <p class="text-sm text-sage font-medium">"{ch.angle}"</p>
          </div>
        ))}
      </div>
      <div class="mt-6 pitch-card">
        <h3 class="font-bold text-lg mb-3">Channel Priority — Where to Start</h3>
        <div class="space-y-2 text-sm text-text-secondary">
          <p><strong class="text-text-primary">1. In-app banner (Day 1):</strong> Reach 100% of existing CUPLA users with zero cost. This is the highest-ROI channel available.</p>
          <p><strong class="text-text-primary">2. Email campaign (Week 1):</strong> 30-50% open rates from existing users. A single well-crafted email can drive thousands of sign-ups.</p>
          <p><strong class="text-text-primary">3. TikTok/Reels (Month 1):</strong> The split-plate concept is inherently visual. "One dinner. Two plates." is a demo that works in 15 seconds.</p>
          <p><strong class="text-text-primary">4. Reddit (Month 1):</strong> r/mealprep, r/EatCheapAndHealthy, r/relationships — authentic problem-solution posts. Zero cost, high engagement.</p>
          <p><strong class="text-text-primary">5. Product Hunt (Month 2):</strong> "Google Docs for food planning" — the launch day announcement. Drives early adopters and press coverage.</p>
          <p><strong class="text-text-primary">6. Couples Influencers (Month 2+):</strong> Partnerships with relationship/lifestyle creators. The "this app reduced our dinner stress" angle is authentic and shareable.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- KPIs BY PHASE -->
  <section class="spoke-section-alt">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="proposal-section-title text-center mb-8">KPIs by Phase</h2>
      <div class="space-y-6">
        <div>
          <h3 class="font-bold text-lg mb-3 text-sage">Phase 1 — Collaboration Core (Months 1-2)</h3>
          <p class="text-xs text-text-secondary mb-3">Goal: Prove couples will adopt a shared food tool. The collaboration layer works.</p>
          <div class="grid grid-cols-2 gap-3">
            {financials.kpis.phase1.map((kpi) => (
              <div class="bg-white rounded-lg border border-border p-3">
                <p class="text-xs text-text-secondary">{kpi.metric}</p>
                <p class="text-sm font-bold text-text-primary">{kpi.target}</p>
              </div>
            ))}
          </div>
        </div>
        <div>
          <h3 class="font-bold text-lg mb-3 text-terracotta-dark">Phase 2 — Smart Recommendations (Months 3-4)</h3>
          <p class="text-xs text-text-secondary mb-3">Goal: Add intelligence layer. The app becomes an active assistant, not passive tool.</p>
          <div class="grid grid-cols-3 gap-3">
            {financials.kpis.phase2.map((kpi) => (
              <div class="bg-white rounded-lg border border-border p-3">
                <p class="text-xs text-text-secondary">{kpi.metric}</p>
                <p class="text-sm font-bold text-text-primary">{kpi.target}</p>
              </div>
            ))}
          </div>
        </div>
        <div>
          <h3 class="font-bold text-lg mb-3 text-sage-dark">Phase 3 — Adaptive Nutrition Engine (Months 5-6)</h3>
          <p class="text-xs text-text-secondary mb-3">Goal: The full moat. Multi-person nutrition optimization difficult to replicate.</p>
          <div class="grid grid-cols-2 gap-3">
            {financials.kpis.phase3.map((kpi) => (
              <div class="bg-white rounded-lg border border-border p-3">
                <p class="text-xs text-text-secondary">{kpi.metric}</p>
                <p class="text-sm font-bold text-text-primary">{kpi.target}</p>
              </div>
            ))}
          </div>
        </div>
        <div>
          <h3 class="font-bold text-lg mb-3 text-text-primary">Technical Performance</h3>
          <div class="grid grid-cols-2 gap-3">
            {financials.kpis.technical.map((kpi) => (
              <div class="bg-white rounded-lg border border-border p-3">
                <p class="text-xs text-text-secondary">{kpi.metric}</p>
                <p class="text-sm font-bold text-text-primary">{kpi.target}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SOURCES & NOTES -->
  <section class="spoke-section-alt">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-sm font-semibold text-text-secondary mb-4">Sources &amp; Notes</h2>
      <ol class="text-xs text-text-secondary space-y-2">
        <li><sup>1</sup> Revenue projections are illustr and based on organic growth assumptions. Actual results will vary based on market conditions, execution quality, and competitive dynamics.</li>
        <li><sup>2</sup> AI cost estimates ($0.01-0.03 per generation) based on Anthropic Claude API pricing (Sonnet model, ~2,000 tokens per meal generation). Actual costs depend on prompt complexity and model choice.</li>
        <li><sup>3</sup> Infrastructure costs are estimates based on typical SaaS hosting patterns. Actual costs depend on chosen technology stack, traffic volume, and provider pricing.</li>
        <li><sup>4</sup> Developer time estimates ($5,000-12,000/mo) vary significantly by region, experience level, and engagement model (full-time employee vs. contractor vs. agency).</li>
        <li><sup>5</sup> Gross margin (85-90%) calculated as: ($10 revenue - $1.00-1.50 AI cost - $0.00-0.02 infra) / $10 revenue. Excludes developer time, marketing, and other operating costs.</li>
        <li><sup>6</sup> Competitor pricing data sourced from public websites and app stores as of May 2026. Pricing may have changed.</li>
        <li><sup>7</sup> CAC organic = $0 refers to paid acquisition cost only. Organic growth still requires content creation, community management, and social media effort.</li>
        <li><sup>8</sup> Premium conversion rate assumptions (8-12%) are based on SaaS industry benchmarks for freemium products. Actual rates require validation.</li>
      </ol>

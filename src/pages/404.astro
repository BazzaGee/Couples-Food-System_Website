---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | Couples Food System" description="The page you're looking for doesn't exist." version="v1">
  <section class="py-20 md:py-32 px-6 max-w-4xl mx-auto text-center">
    <div class="text-8xl md:text-9xl font-semibold text-sage/20 mb-8">404</div>
    <h1 class="text-3xl md:text-4xl font-semibold text-text-primary tracking-tight mb-6">This plate is empty.</h1>
    <p class="text-xl text-text-secondary mb-10 max-w-2xl mx-auto leading-relaxed">
      The page you're looking for doesn't exist. Let's get you back to the kitchen.
    </p>
    <a href="/" class="btn-primary inline-block">
      Back to Home
    </a>
  </section>
</BaseLayout>

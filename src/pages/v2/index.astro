---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroV2 from '../../components/v2/HeroV2.astro';
import FeaturesV2 from '../../components/v2/FeaturesV2.astro';
import WaitlistV2 from '../../components/v2/WaitlistV2.astro';
import WaitlistFormV2 from '../../components/v2/WaitlistFormV2.astro';
import OnePrepTwoPlates from '../../components/infographics/OnePrepTwoPlates.astro';
import ProductLoop from '../../components/infographics/ProductLoop.astro';
import DualModeToggle from '../../components/infographics/DualModeToggle.astro';
import BeforeAfter from '../../components/infographics/BeforeAfter.astro';
import ValueMetrics from '../../components/infographics/ValueMetrics.astro';
---

<BaseLayout title="Couples Food System V2 | Two ways to cook. One perfect dinner." description="The flexible kitchen companion for every couple. Cook now with what you have, or browse hundreds of meals and we'll tell you what to buy." version="v2">
  <HeroV2
    badge="Now accepting Beta waitlist couples"
    headline="One dinner.&#10;Two plates.&#10;Zero arguments."
    subheadline="Don't know what to cook? We'll show you what you can make right now with what you have. Craving something specific? Browse hundreds of meals — we'll tell you exactly what to buy. Either way, one shared recipe, two perfectly portioned plates."
    ctaPrimaryText="Get Early Access — Free During Beta"
    ctaSecondaryText="See How It Works"
    ctaSecondaryHref="/v2/how-it-works"
  />

  <!-- Value Metrics Bar -->
  <ValueMetrics version="v2" />

  <!-- The Big Idea: One Prep, Two Plates -->
  <OnePrepTwoPlates version="v2" />

  <!-- Dual Mode Toggle (V2 Exclusive) -->
  <DualModeToggle version="v2" />

  <!-- Before/After Section -->
  <BeforeAfter version="v2" />

  <!-- Problem Section -->
  <section class="bg-v2-surface-container py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-semibold mb-4 tracking-tight text-v2-on-surface">
          The "What's for dinner?" argument ends tonight.
        </h2>
        <p class="text-xl text-v2-on-surface-variant max-w-2xl mx-auto">
          Sharing a kitchen shouldn't mean compromising on your personal wellness goals — or even just on what to eat. Couples Food System V2 does the heavy lifting.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-v2-surface-container-lowest rounded-3xl border border-v2-outline-variant p-6 shadow-sm">
          <div class="w-12 h-12 rounded-xl bg-v2-secondary-container/30 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E8A87C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-v2-on-surface mb-2">20 Minutes Scrolling</h3>
          <p class="text-v2-on-surface-variant">Endless delivery app scrolling. Still no dinner decided. Sound familiar?</p>
        </div>
        <div class="bg-v2-surface-container-lowest rounded-3xl border border-v2-outline-variant p-6 shadow-sm">
          <div class="w-12 h-12 rounded-xl bg-v2-secondary-container/30 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E8A87C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-v2-on-surface mb-2">One Person Dieting, One Just Wants Dinner</h3>
          <p class="text-v2-on-surface-variant">One person tracks macros while the other just wants to eat. Two meals, two lists, twice the stress.</p>
        </div>
        <div class="bg-v2-surface-container-lowest rounded-3xl border border-v2-outline-variant p-6 shadow-sm">
          <div class="w-12 h-12 rounded-xl bg-v2-secondary-container/30 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E8A87C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-v2-on-surface mb-2">$600/Year Wasted</h3>
          <p class="text-v2-on-surface-variant">Forgotten ingredients rotting in the fridge. Duplicate purchases. Wasted food, wasted money.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works Preview -->
  <section class="py-24 max-w-4xl mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-semibold mb-4 tracking-tight text-v2-on-surface">
        From Plan to Plate in 5 Steps
      </h2>
      <p class="text-xl text-v2-on-surface-variant">
        Two ways to find your meal. One perfect dinner.
      </p>
    </div>
    <div class="space-y-8">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-10 h-10 rounded-full bg-v2-primary text-white text-lg font-semibold flex items-center justify-center">1</div>
        <div>
          <h3 class="text-lg font-semibold text-v2-on-surface mb-1">Invite Your Partner</h3>
          <p class="text-v2-on-surface-variant">Link your accounts to create your shared digital kitchen. "We" replaces "You" from day one.</p>
        </div>
      </div>
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-10 h-10 rounded-full bg-v2-primary text-white text-lg font-semibold flex items-center justify-center">2</div>
        <div>
          <h3 class="text-lg font-semibold text-v2-on-surface mb-1">Set Your Goals</h3>
          <p class="text-v2-on-surface-variant">Partner A wants more energy; Partner B wants to build strength. Or neither of you is dieting — V2 handles it all.</p>
        </div>
      </div>
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-10 h-10 rounded-full bg-v2-primary text-white text-lg font-semibold flex items-center justify-center">3</div>
        <div>
          <h3 class="text-lg font-semibold text-v2-on-surface mb-1">Stock the Pantry</h3>
          <p class="text-v2-on-surface-variant">Type "chicken, rice, spinach" — no barcode scanning. AI uses this to suggest waste-free meals.</p>
        </div>
      </div>
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-10 h-10 rounded-full bg-v2-primary text-white text-lg font-semibold flex items-center justify-center">4</div>
        <div>
          <h3 class="text-lg font-semibold text-v2-on-surface mb-1">Choose Your Mode</h3>
          <p class="text-v2-on-surface-variant">Cook Now for zero-shopping meals from your pantry, or I Want This to browse, pick, and shop for what you're craving.</p>
        </div>
      </div>
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-10 h-10 rounded-full bg-v2-primary text-white text-lg font-semibold flex items-center justify-center">5</div>
        <div>
          <h3 class="text-lg font-semibold text-v2-on-surface mb-1">Cook Together</h3>
          <p class="text-v2-on-surface-variant">Follow one recipe, plate two ways. Same pan. Same meal. Different plates. Eat together in peace.</p>
        </div>
      </div>
    </div>
    <div class="text-center mt-10">
      <a href="/v2/how-it-works" class="text-v2-primary font-medium hover:text-v2-primary/80 inline-flex items-center gap-1">
        See the full walkthrough with illustrations &rarr;
      </a>
    </div>
  </section>

  <!-- Features Section -->
  <FeaturesV2 title="Two ways to cook. One shared kitchen." />

  <!-- Product Loop -->
  <ProductLoop version="v2" />

  <!-- Waitlist CTA -->
  <WaitlistV2>
    <WaitlistFormV2 />
  </WaitlistV2>
</BaseLayout>

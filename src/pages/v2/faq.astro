---
import BaseLayout from '../../layouts/BaseLayout.astro';
import faq from '../../data/v2/faq.json';
import WaitlistV2 from '../../components/v2/WaitlistV2.astro';
import WaitlistFormV2 from '../../components/v2/WaitlistFormV2.astro';
---

<BaseLayout title="FAQ | Couples Food System V2" description="Everything you need to know to get your shared kitchen running smoothly." version="v2">
  <section class="py-20 max-w-3xl mx-auto px-6">
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight mb-6 text-v2-on-surface">Frequently Asked Questions</h1>
      <p class="text-xl text-v2-on-surface-variant">Everything you need to know to get your shared kitchen running smoothly.</p>
    </div>

    {faq.categories.map((category) => (
      <div class="mb-12">
        <h2 class="text-2xl font-semibold text-v2-on-surface mb-6">{category.label}</h2>
        <div class="space-y-6">
          {faq.faq.filter(q => q.category === category.id).map((item) => (
            <details class="bg-v2-surface-container-lowest rounded-3xl border border-v2-outline-variant shadow-sm group">
              <summary class="cursor-pointer p-8 list-none flex items-start justify-between">
                <h3 class="text-xl font-semibold text-v2-on-surface pr-4">{item.question}</h3>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-v2-on-surface-variant w-6 h-6 flex-shrink-0 transition-transform group-open:rotate-180"><path d="m6 9 6 6 6-6"/></svg>
              </summary>
              <div class="px-8 pb-8">
                <p class="text-v2-on-surface-variant text-lg leading-relaxed">{item.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    ))}
  </section>

  <WaitlistV2>
    <WaitlistFormV2 />
  </WaitlistV2>
</BaseLayout>

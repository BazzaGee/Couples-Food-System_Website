---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact | Couples Food System V2" description="Have questions, feedback, or just want to chat about food? We're all ears." version="v2">
  <section class="py-20 max-w-2xl mx-auto px-6">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight mb-6 text-v2-on-surface">Say Hello</h1>
      <p class="text-xl text-v2-on-surface-variant">Have questions, feedback, or just want to chat about food? We're all ears.</p>
    </div>

    <div class="bg-v2-surface-container-lowest p-8 md:p-12 rounded-3xl border border-v2-outline-variant shadow-sm">
      <form action="https://formspree.io/f/barrydgrottis@gmail.com" method="POST" class="flex flex-col gap-6">
        <div>
          <label for="name" class="block font-medium text-v2-on-surface mb-2">Name</label>
          <input type="text" name="name" id="name" required class="w-full px-4 py-4 rounded-xl border border-v2-outline-variant bg-v2-surface-container-lowest text-v2-on-surface focus:outline-none focus:ring-2 focus:ring-v2-primary/50 focus:border-v2-primary transition-all" />
        </div>
        <div>
          <label for="contact_email" class="block font-medium text-v2-on-surface mb-2">Email</label>
          <input type="email" name="email" id="contact_email" required class="w-full px-4 py-4 rounded-xl border border-v2-outline-variant bg-v2-surface-container-lowest text-v2-on-surface focus:outline-none focus:ring-2 focus:ring-v2-primary/50 focus:border-v2-primary transition-all" />
        </div>
        <div>
          <label for="message" class="block font-medium text-v2-on-surface mb-2">Message</label>
          <textarea name="message" id="message" rows="5" required class="w-full px-4 py-4 rounded-xl border border-v2-outline-variant bg-v2-surface-container-lowest text-v2-on-surface focus:outline-none focus:ring-2 focus:ring-v2-primary/50 focus:border-v2-primary transition-all resize-none"></textarea>
        </div>
        <button type="submit" class="bg-v2-primary hover:bg-v2-primary/90 text-v2-on-primary font-medium text-lg py-4 rounded-xl transition-colors mt-2 shadow-sm">
          Send Message
        </button>
      </form>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import features from '../../../data/v2/features.json';
import WaitlistV2 from '../../../components/v2/WaitlistV2.astro';
import WaitlistFormV2 from '../../../components/v2/WaitlistFormV2.astro';

const feature = features.features.find(f => f.id === 'adaptive-cooking')!;
---

<BaseLayout title="Adaptive Shared Cooking | Couples Food System V2" description="One cooking session, two different plates. AI-adapted plating instructions so you both hit your unique goals." version="v2">
  <section class="py-20 max-w-4xl mx-auto px-6">
    <a href="/v2/features" class="text-v2-primary hover:text-v2-primary/80 mb-8 inline-block font-medium">&larr; Back to all features</a>
    <div class="bg-v2-surface-container-lowest rounded-3xl border border-v2-outline-variant p-8 md:p-16 shadow-sm">
      <span class="bg-v2-primary/10 text-v2-primary text-xs px-2 py-1 rounded-full uppercase tracking-wider font-semibold mb-6 inline-block">Signature Feature</span>
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight mb-6 text-v2-on-surface">{feature.title}</h1>
      <p class="text-xl text-v2-on-surface-variant leading-relaxed mb-10">{feature.longDescription}</p>

      <div class="rounded-2xl aspect-video w-full overflow-hidden border border-v2-outline-variant mb-10">
        <img src="/images/screenshots/screenshot-adaptive.webp" alt="Adaptive cooking infographic: one pan splits into two plates - 450 cal plate with more vegetables and 700 cal plate with more protein" class="w-full h-full object-cover" loading="lazy" />
      </div>

      <div class="bg-v2-surface-container rounded-2xl p-8 border border-v2-outline-variant mb-10">
        <h3 class="text-xl font-semibold text-v2-on-surface mb-6">The Adaptive Plating Example</h3>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-v2-surface-container-lowest rounded-2xl p-6 border border-v2-outline-variant">
            <p class="font-semibold text-v2-on-surface mb-2">{feature.example.partnerA.name}</p>
            <p class="text-sm text-v2-on-surface-variant mb-1">Goal: {feature.example.partnerA.goal}</p>
            <p class="text-sm text-v2-on-surface-variant mb-3">~{feature.example.partnerA.calories} cal</p>
            <p class="text-v2-on-surface">{feature.example.partnerA.plate}</p>
          </div>
          <div class="bg-v2-surface-container-lowest rounded-2xl p-6 border border-v2-outline-variant">
            <p class="font-semibold text-v2-on-surface mb-2">{feature.example.partnerB.name}</p>
            <p class="text-sm text-v2-on-surface-variant mb-1">Goal: {feature.example.partnerB.goal}</p>
            <p class="text-sm text-v2-on-surface-variant mb-3">~{feature.example.partnerB.calories} cal</p>
            <p class="text-v2-on-surface">{feature.example.partnerB.plate}</p>
          </div>
        </div>
        <p class="text-center text-v2-on-surface-variant mt-6 font-medium">Same stir-fry. Same pan. Different plates.</p>
      </div>

      <div class="text-lg text-v2-on-surface-variant space-y-6">
        <p>
          When you share a life, you share meals. But traditional meal planning apps treat everyone as an isolated individual. They expect you to either abandon your goals to eat the same thing, or cook completely separate dinners.
        </p>
        <p>
          <strong class="text-v2-on-surface">We solved this.</strong> You follow one single cooking workflow together. When the food is ready, the app provides visual, AI-adapted plating guides. It tells you exactly how much chicken to give Partner A, and how much extra rice to give Partner B.
        </p>
        <p>
          It eliminates friction, reduces dishes, and brings the joy back to a shared kitchen.
        </p>
      </div>

      <ul class="mt-10 space-y-3">
        {feature.benefits.map((benefit) => (
          <li class="flex items-start gap-3 text-lg text-v2-on-surface-variant">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-v2-primary w-6 h-6 flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
            {benefit}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <WaitlistV2>
    <WaitlistFormV2 />
  </WaitlistV2>
</BaseLayout>

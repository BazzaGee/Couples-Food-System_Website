---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import features from '../../../data/v2/features.json';
import WaitlistV2 from '../../../components/v2/WaitlistV2.astro';
import WaitlistFormV2 from '../../../components/v2/WaitlistFormV2.astro';
import OnePrepTwoPlates from '../../../components/infographics/OnePrepTwoPlates.astro';
import DualModeToggle from '../../../components/infographics/DualModeToggle.astro';
---

<BaseLayout title="Features | Couples Food System V2" description="Two ways to cook. One shared kitchen. Discover how V2 makes planning, shopping, and cooking together effortless." version="v2">
  <section class="py-20 max-w-6xl mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h1 class="text-4xl md:text-5xl font-semibold text-v2-on-surface tracking-tight mb-6">Two Ways to Cook. One Perfect Dinner.</h1>
      <p class="text-xl text-v2-on-surface-variant">V2 gives you full agency over your dinner decisions. Cook from your pantry or browse what you're craving — both paths lead to the same adaptive cooking experience.</p>
    </div>

    <!-- Dual Mode Callout (V2 Exclusive) -->
    <DualModeToggle version="v2" />

    <!-- Signature Feature Callout -->
    <OnePrepTwoPlates version="v2" />

    <div class="space-y-8 mt-16">
      {features.features.map((feature, index) => (
        <div class={`bg-v2-surface-container-lowest rounded-3xl border border-v2-outline-variant p-8 md:p-12 flex flex-col md:flex-row gap-8 items-center shadow-sm ${index % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
          <div class="flex-1">
            <h2 class="text-3xl font-semibold mb-4 tracking-tight flex items-center gap-3 text-v2-on-surface">
              {feature.title}
              {feature.badge && (
                <span class="bg-v2-primary/10 text-v2-primary text-xs px-2 py-1 rounded-full uppercase tracking-wider font-semibold">
                  {feature.badge}
                </span>
              )}
            </h2>
            <p class="text-lg text-v2-on-surface-variant mb-6">{feature.shortDescription}</p>
            <a href={feature.href} class="text-v2-primary font-medium hover:text-v2-primary/80 inline-flex items-center gap-1">
              Learn more &rarr;
            </a>
          </div>
          <div class="flex-1 w-full rounded-2xl aspect-video overflow-hidden border border-v2-outline-variant">
            <img src={`/images/v2/screenshot-${feature.id === 'dual-mode-meal-picker' ? 'dual-mode' : feature.id === 'adaptive-cooking' ? 'adaptive' : feature.id === 'shared-grocery-list' ? 'shopping' : feature.id === 'pantry-ai' ? 'pantry' : 'mealplan'}.webp`} alt="{feature.title} app interface" class="w-full h-full object-cover" decoding="async" />
          </div>
        </div>
      ))}
    </div>
  </section>

  <WaitlistV2>
    <WaitlistFormV2 />
  </WaitlistV2>
</BaseLayout>

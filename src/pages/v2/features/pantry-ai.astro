---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import features from '../../../data/v2/features.json';
import WaitlistV2 from '../../../components/v2/WaitlistV2.astro';
import WaitlistFormV2 from '../../../components/v2/WaitlistFormV2.astro';

const feature = features.features.find(f => f.id === 'pantry-ai')!;
---

<BaseLayout title="Pantry-First AI | Couples Food System V2" description="Your fridge just became a menu. Tell the app what you have, and our AI generates a list of perfect meals to reduce waste and save a trip to the store." version="v2">
  <section class="py-20 max-w-4xl mx-auto px-6">
    <a href="/v2/features" class="text-v2-primary hover:text-v2-primary/80 mb-8 inline-block font-medium">&larr; Back to all features</a>
    <div class="bg-v2-surface-container-lowest rounded-3xl border border-v2-outline-variant p-8 md:p-16 shadow-sm">
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight mb-6 text-v2-on-surface">{feature.title}</h1>
      <p class="text-xl text-v2-on-surface-variant leading-relaxed mb-10">{feature.longDescription}</p>

      <div class="rounded-2xl aspect-video w-full overflow-hidden border border-v2-outline-variant mb-10">
        <img src="/images/v2/screenshot-pantry.webp" alt="Pantry-first AI app interface showing natural language input and AI-generated meal suggestions" class="w-full h-full object-cover" decoding="async" />
      </div>

      <!-- The Problem This Solves -->
      <div class="mb-10">
        <h3 class="text-xl font-semibold text-v2-on-surface mb-4">The Problem This Solves</h3>
        <p class="text-lg text-v2-on-surface-variant leading-relaxed">
          Stop staring into the fridge wondering what to cook. Most meal apps start with recipes and work backward to a grocery list. But that assumes you're starting from scratch. What about the chicken that expires tomorrow? The half-onion from last night's dinner? The rice you bought in bulk? Traditional apps ignore what you already have.
        </p>
      </div>

      <!-- How It Works -->
      <div class="mb-10">
        <h3 class="text-xl font-semibold text-v2-on-surface mb-4">How It Works</h3>
        <div class="space-y-4 text-lg text-v2-on-surface-variant">
          <p>
            <strong class="text-v2-on-surface">Natural language input.</strong> Type or dictate: "We have chicken, rice, spinach, and half an onion." No barcode scanning. No manual item entry. The AI parses your ingredients automatically.
          </p>
          <p>
            <strong class="text-v2-on-surface">AI generates a list of meals.</strong> In V2, the AI generates multiple meals — not just one — so you can choose what appeals to you tonight. Every ingredient marked green (you have it) or orange (you need it).
          </p>
          <p>
            <strong class="text-v2-on-surface">One tap to shop.</strong> Missing ingredients? One tap adds them to your shared grocery list. Both partners see the update instantly.
          </p>
        </div>
      </div>

      <!-- Why Others Don't Do This -->
      <div class="mb-10">
        <h3 class="text-xl font-semibold text-v2-on-surface mb-4">Why Others Don't Do This</h3>
        <p class="text-lg text-v2-on-surface-variant leading-relaxed">
          No mainstream app has a pantry tab at all. This is the input for AI meal generation. Without knowing what you have, meal suggestions are useless. Most apps push barcode scanning — slow, friction-heavy, and impractical for a full pantry. Natural language input is faster and more intuitive.
        </p>
      </div>

      <ul class="mt-10 space-y-3">
        {feature.benefits.map((benefit) => (
          <li class="flex items-start gap-3 text-lg text-v2-on-surface-variant">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-v2-primary w-6 h-6 flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
            {benefit}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <WaitlistV2>
    <WaitlistFormV2 />
  </WaitlistV2>
</BaseLayout>

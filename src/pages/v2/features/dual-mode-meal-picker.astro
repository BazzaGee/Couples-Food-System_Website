---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import features from '../../../data/v2/features.json';
import WaitlistV2 from '../../../components/v2/WaitlistV2.astro';
import WaitlistFormV2 from '../../../components/v2/WaitlistFormV2.astro';

const feature = features.features.find(f => f.id === 'dual-mode-meal-picker')!;
---

<BaseLayout title="Dual-Mode Meal Picker | Couples Food System V2" description="Two ways to cook: Cook Now (pantry-first, zero shopping) or I Want This (browse, pick, and shop). One shared recipe, two perfectly portioned plates." version="v2">
  <section class="py-20 max-w-4xl mx-auto px-6">
    <a href="/v2/features" class="text-v2-primary hover:text-v2-primary/80 mb-8 inline-block font-medium">&larr; Back to all features</a>
    <div class="bg-v2-surface-container-lowest rounded-3xl border border-v2-outline-variant p-8 md:p-16 shadow-sm">
      <span class="bg-v2-primary/10 text-v2-primary text-xs px-2 py-1 rounded-full uppercase tracking-wider font-semibold mb-6 inline-block">New in V2</span>
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight mb-6 text-v2-on-surface">{feature.title}</h1>
      <p class="text-xl text-v2-on-surface-variant leading-relaxed mb-10">{feature.longDescription}</p>

      <div class="rounded-2xl aspect-video w-full overflow-hidden border border-v2-outline-variant mb-10">
        <img src="/images/screenshots/screenshot-adaptive.webp" alt="Dual-mode meal picker showing Cook Now and I Want This toggle with meal cards" class="w-full h-full object-cover" loading="lazy" />
      </div>

      <!-- Dual Mode Example -->
      <div class="bg-v2-surface-container rounded-2xl p-8 border border-v2-outline-variant mb-10">
        <h3 class="text-xl font-semibold text-v2-on-surface mb-6">Two Modes, One Perfect Dinner</h3>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-v2-surface-container-lowest rounded-2xl p-6 border border-v2-primary/30">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-4 h-4 rounded-full bg-v2-primary"></div>
              <p class="font-semibold text-v2-on-surface">{feature.example.cookNow.label}</p>
            </div>
            <p class="text-sm text-v2-on-surface-variant mb-3">{feature.example.cookNow.meals}</p>
            <span class="inline-block text-xs bg-v2-primary/10 text-v2-primary px-3 py-1 rounded-full">{feature.example.cookNow.badge}</span>
          </div>
          <div class="bg-v2-surface-container-lowest rounded-2xl p-6 border border-v2-outline-variant">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-4 h-4 rounded-full bg-v2-outline"></div>
              <p class="font-semibold text-v2-on-surface">{feature.example.iWantThis.label}</p>
            </div>
            <p class="text-sm text-v2-on-surface-variant mb-3">{feature.example.iWantThis.meals}</p>
            <span class="inline-block text-xs bg-v2-secondary-container/30 text-v2-on-secondary-container px-3 py-1 rounded-full">{feature.example.iWantThis.badge}</span>
          </div>
        </div>
        <p class="text-center text-v2-on-surface-variant mt-6 font-medium">Same adaptive cooking layer underneath. Two ways to get there.</p>
      </div>

      <div class="text-lg text-v2-on-surface-variant space-y-6">
        <p>
          V1 gave you one meal with no choice. V2 gives you a list of meals to choose from, or a visual grid to browse through. Both modes feed into the same adaptive cooking layer — one meal, two plates, both perfect.
        </p>
        <p>
          <strong class="text-v2-on-surface">Cook Now</strong> is for when you want dinner without a trip to the store. AI scans your pantry and shows you everything you can make right now.
        </p>
        <p>
          <strong class="text-v2-on-surface">I Want This</strong> is for when you're craving something specific. Browse a curated recipe database, see what you have vs. what you need, and add missing ingredients to your shopping list in one tap.
        </p>
      </div>

      <ul class="mt-10 space-y-3">
        {feature.benefits.map((benefit) => (
          <li class="flex items-start gap-3 text-lg text-v2-on-surface-variant">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-v2-primary w-6 h-6 flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
            {benefit}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <WaitlistV2>
    <WaitlistFormV2 />
  </WaitlistV2>
</BaseLayout>

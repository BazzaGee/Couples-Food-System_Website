---
import BaseHead from '../components/layout/BaseHead.astro';
import Header from '../components/layout/Header.astro';
import VersionToggle from '../components/layout/VersionToggle.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
  version?: 'v1' | 'v2';
}

const { title, description, canonicalURL, ogImage, version = 'v1' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} canonicalURL={canonicalURL} ogImage={ogImage} version={version} />
  </head>
  <body class={`min-h-screen flex flex-col ${version === 'v2' ? 'pt-28 bg-v2-surface text-v2-on-surface' : 'pt-28'}`}>
    <Header version={version} />
    <VersionToggle version={version} />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer version={version} />
  </body>
</html>

---
import features from '../../data/features.json';

interface Props {
  title?: string;
  showLink?: boolean;
}

const { title = 'Your shared kitchen, smarter.', showLink = true } = Astro.props;
---

<section class="py-24 max-w-6xl mx-auto px-6">
  <div class="text-center mb-16">
    <h2 class="text-3xl md:text-4xl font-semibold mb-4 tracking-tight">{title}</h2>
    <p class="text-xl text-text-secondary max-w-2xl mx-auto">Every feature built for two people sharing one kitchen. Not a solo user. Not a family. Just you and your partner.</p>
  </div>
  <div class="grid md:grid-cols-2 gap-8">
    {features.features.map((feature) => (
      <a
        href={showLink ? feature.href : undefined}
        class="block card group"
      >
        <div class="bg-cream-dark w-14 h-14 rounded-xl flex items-center justify-center mb-6 group-hover:bg-sage/20 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7 text-sage-dark">
            {feature.icon === 'utensils' && <><path d="m2.5 1.5-1 2.5 2 1 3-1 1-2.5-2-1z"/><path d="m19.5 4.5-1 2.5 2 1 3-1 1-2.5-2-1z"/><path d="M5 3v18a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3"/><path d="M5 12h14"/></>}
            {feature.icon === 'refresh-cw' && <><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></>}
            {feature.icon === 'carrot' && <><path d="M2.3 11.7c.4-.4.9-.7 1.4-.7 2.3 0 4.3 1 5.8 2.5L16 20l3-3-6.5-6.5c-1.5-1.5-2.5-3.5-2.5-5.8 0-.5.3-1 .7-1.4"/><path d="M15 5l4 4"/><path d="M19 9l-1.5 1.5"/><path d="M17 11l1.5 1.5"/></>}
            {feature.icon === 'calendar-heart' && <><path d="M21 10.5V3h-4.5"/><path d="M16.5 3H7.5C6.12 3 5 4.12 5 5.5v13.9c0 .75.38 1.42.97 1.82"/><path d="M21 10.5c1.38 0 2.5 1.12 2.5 2.5v7.5c0 1.38-1.12 2.5-2.5 2.5H3c-1.38 0-2.5-1.12-2.5-2.5V13c0-1.38 1.12-2.5 2.5-2.5"/><path d="M16 3v4"/><path d="M8 3v4"/><path d="M3 10h18"/><path d="m19.5 14.5-1.5 1.5 3 3"/></>}
          </svg>
        </div>
        <h3 class="text-2xl font-semibold mb-3 tracking-tight flex items-center gap-3">
          {feature.title}
          {feature.badge && (
            <span class={feature.badgeType === 'primary' ? 'badge-signature' : 'badge-unique'}>
              {feature.badge}
            </span>
          )}
        </h3>
        <p class="text-text-secondary leading-relaxed text-lg">{feature.shortDescription}</p>
        {showLink && (
          <span class="inline-flex items-center gap-1 text-sage font-medium mt-4 group-hover:gap-2 transition-all">
            Learn more <span>&rarr;</span>
          </span>
        )}
      </a>
    ))}
  </div>
</section>

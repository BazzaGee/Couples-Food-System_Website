---
import comparison from '../../data/comparison.json';

interface Props {
  title?: string;
  subtitle?: string;
}

const { title = 'Why Generic Apps Fail Couples', subtitle = 'Most popular apps are designed for isolated individuals. They force you to choose between eating the exact same portions or cooking completely separate meals. Here is how we change the game.' } = Astro.props;
---

<section class="py-20 max-w-5xl mx-auto px-6">
  <div class="text-center mb-16">
    <h1 class="text-4xl md:text-5xl font-semibold tracking-tight mb-6">{title}</h1>
    <p class="text-xl text-text-secondary max-w-3xl mx-auto">{subtitle}</p>
  </div>

  <div class="bg-white rounded-2xl border border-border overflow-hidden shadow-sm">
    <div class="grid grid-cols-3 bg-cream-dark p-6 border-b border-border font-semibold text-text-primary text-sm md:text-base">
      <div>Feature</div>
      <div class="text-center text-sage-dark">Couples Food System</div>
      <div class="text-center text-text-secondary">Standard Diet Apps</div>
    </div>

    {comparison.comparisons.map((item) => (
      <div class="grid grid-cols-3 p-6 border-b border-border items-center">
        <div class="font-medium text-sm md:text-base">{item.feature}</div>
        <div class="flex justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sage w-7 h-7"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
        </div>
        <div class="flex justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-secondary/30 w-7 h-7"><path d="m15 9-6 6"/><path d="m9 9 6 6"/><path d="M20 4H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Z"/></svg>
        </div>
      </div>
    ))}
  </div>

  <div class="mt-16 space-y-8 text-lg text-text-secondary">
    {comparison.genericCompetitors.map((competitor) => (
      <div>
        <p class="font-semibold text-text-primary mb-2">{competitor.type}</p>
        <p>{competitor.problem}</p>
      </div>
    ))}
  </div>

  <div class="mt-12 bg-sage/10 rounded-2xl p-8 md:p-12 text-center">
    <p class="text-xl text-text-primary font-medium">
      Couples Food System is the only app built from the ground up for two people sharing one kitchen with different goals. We combine real-time collaboration, AI meal generation, adaptive portions, pantry-first intelligence, and relationship-first design into one seamless experience.
    </p>
  </div>

  <!-- Venn Diagram -->
  <section class="mt-16 max-w-4xl mx-auto">
    <h2 class="text-3xl font-semibold text-center mb-8 tracking-tight text-text-primary">Where We Fit In</h2>
    <div class="rounded-2xl overflow-hidden shadow-lg border border-border">
      <img src="/images/diagrams/venn-diagram.webp" alt="Venn diagram showing Couples Food System at the intersection of Pantry AI, Nutrition Intelligence, Real-Time Collaboration, and Grocery Sync" class="w-full h-auto" loading="lazy" />
    </div>
    <p class="text-center text-text-secondary mt-4 text-sm">No other app sits at the center of all four circles.</p>
  </section>
</section>

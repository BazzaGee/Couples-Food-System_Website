---
interface Props {
  children: any;
}

const { children } = Astro.props;
---

<section id="waitlist" class="py-24 bg-sage/10">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <h2 class="text-3xl md:text-4xl font-semibold tracking-tight mb-4 text-text-primary">
      Get Early Access — Free During Beta
    </h2>
    <p class="text-xl text-text-secondary mb-8 max-w-xl mx-auto">
      Join the waitlist and be among the first couples to experience the shared kitchen that adapts to both of you. No credit card required.
    </p>
    <div class="bg-white rounded-2xl border border-border p-8 md:p-12 shadow-sm">
      {children}
    </div>
    <p class="text-sm text-text-secondary mt-6">
      Limited Beta spots available. We'll notify you as soon as access opens.
    </p>
  </div>
</section>

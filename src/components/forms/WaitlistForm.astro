---
const FORMSPREE_URL = 'https://formspree.io/f/xpznqzvg';
---

<form action={FORMSPREE_URL} method="POST" class="space-y-4">
  <div class="grid md:grid-cols-2 gap-4">
    <div>
      <label for="partner1Name" class="block text-sm font-medium text-text-primary mb-1">Partner 1 Name</label>
      <input type="text" id="partner1Name" name="partner1Name" required class="w-full px-4 py-3 rounded-xl border border-border bg-white focus:ring-2 focus:ring-sage focus:border-sage outline-none transition-all" placeholder="Your name" />
    </div>
    <div>
      <label for="partner2Name" class="block text-sm font-medium text-text-primary mb-1">Partner 2 Name</label>
      <input type="text" id="partner2Name" name="partner2Name" required class="w-full px-4 py-3 rounded-xl border border-border bg-white focus:ring-2 focus:ring-sage focus:border-sage outline-none transition-all" placeholder="Your partner's name" />
    </div>
  </div>
  <div>
    <label for="email" class="block text-sm font-medium text-text-primary mb-1">Email Address</label>
    <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-border bg-white focus:ring-2 focus:ring-sage focus:border-sage outline-none transition-all" placeholder="you@example.com" />
  </div>
  <div>
    <label for="cookingStyle" class="block text-sm font-medium text-text-primary mb-1">How do you currently handle dinner?</label>
    <select id="cookingStyle" name="cookingStyle" class="w-full px-4 py-3 rounded-xl border border-border bg-white focus:ring-2 focus:ring-sage focus:border-sage outline-none transition-all">
      <option value="">Select one...</option>
      <option value="separate-meals">We cook separate meals</option>
      <option value="compromise">We compromise and eat the same thing</option>
      <option value="takeout">We order takeout most nights</option>
      <option value="one-cooks">One person does all the cooking</option>
      <option value="other">Other</option>
    </select>
  </div>
  <button type="submit" class="btn-primary w-full">
    Join Free Beta Waitlist
  </button>
  <p class="text-xs text-text-secondary text-center">
    No spam. No credit card. Just early access to the app that ends the dinner argument.
  </p>
</form>

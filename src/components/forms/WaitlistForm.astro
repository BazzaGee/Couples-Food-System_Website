---
const formspreeEndpoint = 'https://formspree.io/f/barrydgrottis@gmail.com';
---

<form action={formspreeEndpoint} method="POST" class="flex flex-col gap-4">
  <div class="flex flex-col md:flex-row gap-4">
    <div class="flex-1">
      <label for="waitlist_email" class="sr-only">Your Email</label>
      <input type="email" name="email" id="waitlist_email" required placeholder="Your email address" class="input-field" />
    </div>
    <div class="flex-1">
      <label for="partner_email" class="sr-only">Partner's Email</label>
      <input type="email" name="partner_email" id="partner_email" placeholder="Partner's email (optional)" class="input-field" />
    </div>
  </div>

  <div>
    <label for="goal" class="sr-only">Primary Goal</label>
    <select name="primary_goal" id="goal" required class="input-field appearance-none text-text-secondary">
      <option value="" disabled selected>What is your shared primary goal?</option>
      <option value="Stop arguing about dinner">Stop arguing about "what's for dinner"</option>
      <option value="Different portion/diet goals">Eat the same meals but with different portion goals</option>
      <option value="Reduce food waste">Reduce food waste and save money</option>
    </select>
  </div>

  <button type="submit" class="w-full bg-sage hover:bg-sage-dark text-white font-semibold text-lg py-4 rounded-xl transition-colors mt-2 shadow-sm">
    Join Free Beta Waitlist
  </button>
</form>

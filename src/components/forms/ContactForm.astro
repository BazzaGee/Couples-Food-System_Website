---
const formspreeEndpoint = 'https://formspree.io/f/barrydgrottis@gmail.com';
---

<form action={formspreeEndpoint} method="POST" class="flex flex-col gap-6">
  <div>
    <label for="name" class="block font-medium text-text-primary mb-2">Name</label>
    <input type="text" name="name" id="name" required class="input-field" />
  </div>
  <div>
    <label for="contact_email" class="block font-medium text-text-primary mb-2">Email</label>
    <input type="email" name="email" id="contact_email" required class="input-field" />
  </div>
  <div>
    <label for="message" class="block font-medium text-text-primary mb-2">Message</label>
    <textarea name="message" id="message" rows="5" required class="input-field resize-none"></textarea>
  </div>
  <button type="submit" class="bg-sage hover:bg-sage-dark text-white font-medium text-lg py-4 rounded-xl transition-colors mt-2 shadow-sm">
    Send Message
  </button>
</form>

---
---
<div class="flex justify-center py-8">
  <svg viewBox="0 0 500 200" class="w-full max-w-lg" xmlns="http://www.w3.org/2000/svg">
    <!-- Pantry -->
    <rect x="10" y="60" width="110" height="80" rx="16" fill="rgba(122, 158, 126, 0.1)" stroke="#7A9E7E" stroke-width="2"/>
    <text x="65" y="95" text-anchor="middle" fill="#2C3E2D" font-size="13" font-weight="700" font-family="Inter, sans-serif">PANTRY</text>
    <text x="65" y="115" text-anchor="middle" fill="#6B7B6C" font-size="10" font-family="Inter, sans-serif">What you have</text>
    <!-- Arrow Pantry → AI -->
    <line x1="125" y1="100" x2="175" y2="100" stroke="#7A9E7E" stroke-width="2" marker-end="url(#arrowhead)"/>
    <text x="150" y="90" text-anchor="middle" fill="#5A7E5E" font-size="8" font-family="Inter, sans-serif">suggests</text>

    <!-- AI Meals -->
    <rect x="180" y="60" width="110" height="80" rx="16" fill="rgba(232, 168, 124, 0.1)" stroke="#E8A87C" stroke-width="2"/>
    <text x="235" y="95" text-anchor="middle" fill="#2C3E2D" font-size="13" font-weight="700" font-family="Inter, sans-serif">AI MEALS</text>
    <text x="235" y="115" text-anchor="middle" fill="#6B7B6C" font-size="10" font-family="Inter, sans-serif">What to cook</text>
    <!-- Arrow AI → Shopping -->
    <line x1="295" y1="100" x2="345" y2="100" stroke="#E8A87C" stroke-width="2" marker-end="url(#arrowhead)"/>
    <text x="320" y="90" text-anchor="middle" fill="#C88A5C" font-size="8" font-family="Inter, sans-serif">missing →</text>

    <!-- Shopping -->
    <rect x="350" y="60" width="110" height="80" rx="16" fill="rgba(122, 158, 126, 0.1)" stroke="#7A9E7E" stroke-width="2"/>
    <text x="405" y="95" text-anchor="middle" fill="#2C3E2D" font-size="13" font-weight="700" font-family="Inter, sans-serif">SHOPPING</text>
    <text x="405" y="115" text-anchor="middle" fill="#6B7B6C" font-size="10" font-family="Inter, sans-serif">What to buy</text>

    <!-- Loop back arrow -->
    <path d="M 405 140 Q 405 180 235 180 Q 65 180 65 140" fill="none" stroke="#7A9E7E" stroke-width="1.5" stroke-dasharray="4,3" marker-end="url(#arrowhead)"/>
    <text x="235" y="175" text-anchor="middle" fill="#5A7E5E" font-size="9" font-weight="600" font-family="Inter, sans-serif">Check off → Move to Pantry → Repeat</text>

    <!-- Arrow marker -->
    <defs>
      <marker id="arrowhead" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
        <polygon points="0 0, 8 3, 0 6" fill="#7A9E7E"/>
      </marker>
    </defs>
  </svg>
</div>

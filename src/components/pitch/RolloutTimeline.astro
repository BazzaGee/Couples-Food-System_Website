---
import financials from '../../data/pitch/financials.json';

const phases = financials.phases;
---
<div class="py-8">
  <div class="space-y-8">
    {phases.map((phase, i) => (
      <div class="flex gap-6">
        <div class="flex flex-col items-center">
          <div class="timeline-dot"></div>
          {i < phases.length - 1 && <div class="timeline-line flex-1 min-h-[40px]"></div>}
        </div>
        <div class="pb-8">
          <div class="flex items-center gap-3 mb-2">
            <span class="badge-signature">{phase.phase}</span>
            <span class="text-xs text-text-secondary font-medium">{phase.timeline}</span>
          </div>
          <h4 class="text-lg font-bold text-text-primary mb-1">{phase.title}</h4>
          <p class="text-sm text-text-secondary mb-4">{phase.goal}</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-4">
            {phase.features.map((f) => (
              <div class="text-xs bg-cream-dark rounded-lg px-3 py-2 border border-border">
                <span class="font-semibold text-text-primary">{f.name}</span>
                <span class="block text-text-secondary mt-0.5">{f.benefit}</span>
              </div>
            ))}
          </div>
          <div class="bg-sage/5 rounded-lg p-3 border border-sage/20">
            <p class="text-xs font-semibold text-sage mb-1">Success Criteria:</p>
            <div class="grid grid-cols-2 gap-1">
              {phase.successCriteria.map((sc) => (
                <span class="text-xs text-text-secondary">{sc.metric}: <span class="font-semibold text-text-primary">{sc.target}</span></span>
              ))}
            </div>
          </div>
          <p class="text-xs text-text-secondary mt-3 italic">{phase.proves}</p>
        </div>
      </div>
    ))}
  </div>
</div>

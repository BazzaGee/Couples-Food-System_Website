---
interface Props {
  number: string;
  label: string;
  sublabel?: string;
}
const { number, label, sublabel } = Astro.props;
---
<div class="stat-card">
  <div class="stat-number">{number}</div>
  <div class="stat-label">{label}</div>
  {sublabel && <p class="text-xs text-text-secondary mt-1">{sublabel}</p>}
</div>

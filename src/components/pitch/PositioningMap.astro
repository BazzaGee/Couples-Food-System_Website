---
---
<div class="flex justify-center py-8">
  <svg viewBox="0 0 500 400" class="w-full max-w-lg" xmlns="http://www.w3.org/2000/svg">
    <!-- Axes -->
    <line x1="50" y1="200" x2="450" y2="200" stroke="#E5E1DA" stroke-width="1"/>
    <line x1="250" y1="20" x2="250" y2="380" stroke="#E5E1DA" stroke-width="1"/>

    <!-- Axis labels -->
    <text x="250" y="15" text-anchor="middle" fill="#7A9E7E" font-size="11" font-weight="600" font-family="Inter, sans-serif">NUTRITION FOCUS ↑</text>
    <text x="250" y="395" text-anchor="middle" fill="#E8A87C" font-size="11" font-weight="600" font-family="Inter, sans-serif">RELATIONSHIP FOCUS ↑</text>
    <text x="15" y="205" fill="#7A9E7E" font-size="10" font-weight="600" font-family="Inter, sans-serif" transform="rotate(-90 15 205)">PANTRY FOCUS</text>
    <text x="485" y="205" text-anchor="end" fill="#E8A87C" font-size="10" font-weight="600" font-family="Inter, sans-serif" transform="rotate(90 485 205)">COLLABORATION</text>

    <!-- Competitor dots -->
    <!-- Eat This Much - high nutrition, low collab -->
    <circle cx="350" cy="80" r="6" fill="#E8A87C" opacity="0.7"/>
    <text x="350" y="70" text-anchor="middle" fill="#2C3E2D" font-size="9" font-family="Inter, sans-serif">Eat This Much</text>

    <!-- Fitia - high nutrition, medium collab -->
    <circle cx="320" cy="120" r="8" fill="#E8A87C" opacity="0.8"/>
    <text x="320" y="108" text-anchor="middle" fill="#2C3E2D" font-size="9" font-weight="600" font-family="Inter, sans-serif">Fitia</text>

    <!-- KitchenSync - high pantry, low collab -->
    <circle cx="130" cy="250" r="6" fill="#7A9E7E" opacity="0.6"/>
    <text x="130" y="240" text-anchor="middle" fill="#2C3E2D" font-size="9" font-family="Inter, sans-serif">KitchenSync</text>

    <!-- Leanlife - high collab, low nutrition -->
    <circle cx="370" cy="300" r="7" fill="#7A9E7E" opacity="0.7"/>
    <text x="370" y="318" text-anchor="middle" fill="#2C3E2D" font-size="9" font-weight="600" font-family="Inter, sans-serif">Leanlife</text>

    <!-- Yummo - medium nutrition, medium collab -->
    <circle cx="280" cy="260" r="7" fill="#E8A87C" opacity="0.7"/>
    <text x="280" y="278" text-anchor="middle" fill="#2C3E2D" font-size="9" font-weight="600" font-family="Inter, sans-serif">Yummo</text>

    <!-- PlateMates -->
    <circle cx="300" cy="290" r="6" fill="#E8A87C" opacity="0.6"/>
    <text x="300" y="308" text-anchor="middle" fill="#2C3E2D" font-size="9" font-family="Inter, sans-serif">PlateMates</text>

    <!-- AnyList - high collab, no nutrition -->
    <circle cx="400" cy="340" r="6" fill="#7A9E7E" opacity="0.6"/>
    <text x="400" y="358" text-anchor="middle" fill="#2C3E2D" font-size="9" font-family="Inter, sans-serif">AnyList</text>

    <!-- Samsung Food -->
    <circle cx="300" cy="180" r="6" fill="#6B7B6C" opacity="0.5"/>
    <text x="300" y="170" text-anchor="middle" fill="#2C3E2D" font-size="9" font-family="Inter, sans-serif">Samsung</text>

    <!-- CUPLA - center of everything (bottom-right quadrant) -->
    <circle cx="380" cy="240" r="14" fill="rgba(122, 158, 126, 0.3)" stroke="#5A7E5E" stroke-width="2.5"/>
    <text x="380" y="236" text-anchor="middle" fill="#2C3E2D" font-size="12" font-weight="700" font-family="Inter, sans-serif">CUPLA</text>
    <text x="380" y="252" text-anchor="middle" fill="#5A7E5E" font-size="8" font-weight="600" font-family="Inter, sans-serif">Target Position</text>
  </svg>
</div>

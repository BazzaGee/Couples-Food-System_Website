        <div class="flex-1 bg-border/30 rounded-full h-8 relative overflow-hidden">
          <div class="absolute left-0 top-0 h-full bg-sage/30 rounded-full" style="width: 3%"></div>
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-xs font-semibold text-text-primary">$400-600/mo</span>
        </div>
      </div>
      <!-- Year 1 -->
      <div class="flex items-center gap-4">
        <span class="text-xs text-text-secondary w-20 text-right font-medium">Year 1</span>
        <div class="flex-1 bg-border/30 rounded-full h-8 relative overflow-hidden">
          <div class="absolute left-0 top-0 h-full bg-sage/40 rounded-full" style="width: 12%"></div>
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-xs font-semibold text-text-primary">$2,400-3,600/mo</span>

        </div>
        <div class="text-right">
          <span class="bg-sage/10 text-sage-dark text-sm font-bold px-3 py-1 rounded-full">28.1% CAGR</span>
        </div>
      </div>
      <!-- Bar chart -->
      <div class="flex items-end gap-2 h-32">
        <div class="flex-1 bg-sage/20 rounded-t" style="height: 15%">
          <span class="block text-center text-[9px] text-text-secondary mt-1">2024</span>
        </div>
        <div class="flex-1 bg-sage/25 rounded-t" style="height: 20%">

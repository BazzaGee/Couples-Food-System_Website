        </div>
        <div class="flex-1 bg-sage/35 rounded-t" style="height: 32%">
          <span class="block text-center text-[9px] text-text-secondary mt-1">2027</span>
        </div>
        <div class="flex-1 bg-sage/40 rounded-t" style="height: 40%">
          <span class="block text-center text-[9px] text-text-secondary mt-1">2028</span>
        </div>
        <div class="flex-1 bg-sage/50 rounded-t" style="height: 50%">

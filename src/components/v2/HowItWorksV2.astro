---
import features from '../../data/v2/features.json';

interface Props {
  title?: string;
  subtitle?: string;
}

const { title = 'From Plan to Plate in 5 Steps', subtitle = "Two ways to find your meal, one perfect dinner. A self-reinforcing loop that makes dinner easier every single day." } = Astro.props;
const steps = features.steps;
---

<section class="py-20 max-w-4xl mx-auto px-6">
  <div class="text-center mb-16">
    <h1 class="text-4xl md:text-5xl font-semibold tracking-tight mb-6 text-v2-on-surface">{title}</h1>
    <p class="text-xl text-v2-on-surface-variant">{subtitle}</p>
  </div>

  <div class="space-y-12">
    {steps.map((step, index) => (
      <div class="flex flex-col md:flex-row gap-6 md:gap-12 items-start relative">
        {index < steps.length - 1 && (
          <div class="hidden md:block absolute left-8 top-20 bottom-[-3rem] w-0.5 bg-v2-outline-variant"></div>
        )}
        <div class="flex-shrink-0 w-16 h-16 rounded-full bg-v2-primary text-white text-2xl font-semibold flex items-center justify-center z-10 shadow-sm border-4 border-v2-surface">
          {step.number}
        </div>
        <div class="bg-v2-surface-container-lowest flex-1 rounded-3xl border border-v2-outline-variant p-8 shadow-sm">
          <h3 class="text-2xl font-semibold mb-3 tracking-tight text-v2-on-surface">{step.title}</h3>
          <p class="text-lg text-v2-on-surface-variant mb-4">{step.description}</p>
          
          {step.number === 4 && (
            <div class="mt-4 bg-v2-surface-container rounded-2xl p-6 border border-v2-outline-variant">
              <p class="text-sm font-semibold text-v2-primary mb-4">Choose how you want to find dinner tonight:</p>
              <div class="flex flex-col sm:flex-row gap-4">
                <div class="flex-1 bg-v2-surface-container-lowest rounded-xl p-4 border border-v2-primary/30">
                  <div class="flex items-center gap-2 mb-2">
                    <div class="w-3 h-3 rounded-full bg-v2-primary"></div>
                    <span class="font-semibold text-v2-on-surface text-sm">Cook Now</span>
                  </div>
                  <p class="text-sm text-v2-on-surface-variant">Show me what I can make with what I have. Zero shopping.</p>
                </div>
                <div class="flex-1 bg-v2-surface-container-lowest rounded-xl p-4 border border-v2-outline-variant">
                  <div class="flex items-center gap-2 mb-2">
                    <div class="w-3 h-3 rounded-full bg-v2-outline"></div>
                    <span class="font-semibold text-v2-on-surface-variant text-sm">I Want This</span>
                  </div>
                  <p class="text-sm text-v2-on-surface-variant">Let me browse meals, pick what I'm craving, and tell me what to buy.</p>
                </div>
              </div>
            </div>
          )}
          
          <div class="rounded-2xl overflow-hidden border border-v2-outline-variant mt-4">
            <img src={`/images/v2/step-${step.number === 1 ? '1-invite' : step.number === 2 ? '2-goals' : step.number === 3 ? '3-pantry' : step.number === 4 ? '4-choose-mode' : '5-cook'}.webp`} alt="Step {step.number}: {step.title} illustration" class="w-full h-auto" decoding="async" />
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Product Loop Explanation -->
  <div class="mt-16 bg-v2-primary/10 rounded-3xl p-8 md:p-12 text-center border border-v2-outline-variant">
    <h3 class="text-2xl font-semibold text-v2-on-surface mb-4">The Loop That Never Stops</h3>
    <p class="text-lg text-v2-on-surface-variant max-w-2xl mx-auto">
      Pantry → AI suggests meals → Shopping list for missing items → Buy groceries → Move to Pantry → repeat. In V2, you have two entry points (Cook Now and I Want This), but both feed into the same loop. The more you use it, the smarter it gets.
    </p>
  </div>
</section>

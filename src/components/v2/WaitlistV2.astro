---
interface Props {
  children: any;
}

const { children } = Astro.props;
---

<section id="waitlist" class="py-24 bg-v2-surface-container">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <h2 class="text-3xl md:text-4xl font-semibold tracking-tight mb-4 text-v2-on-surface">
      Get Early Access — Free During Beta
    </h2>
    <p class="text-xl text-v2-on-surface-variant mb-8 max-w-xl mx-auto">
      Join the waitlist and be among the first couples to experience the flexible kitchen companion that works whether you're dieting or not. No credit card required.
    </p>
    <div class="bg-v2-surface-container-lowest rounded-3xl border border-v2-outline-variant p-8 md:p-12 shadow-sm">
      {children}
    </div>
    <p class="text-sm text-v2-on-surface-variant mt-6">
      Limited Beta spots available. We'll notify you as soon as access opens.
    </p>
  </div>
</section>

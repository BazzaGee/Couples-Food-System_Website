---
const formspreeEndpoint = 'https://formspree.io/f/barrydgrottis@gmail.com';
---

<form action={formspreeEndpoint} method="POST" class="flex flex-col gap-4">
  <div class="flex flex-col md:flex-row gap-4">
    <div class="flex-1">
      <label for="waitlist_email_v2" class="sr-only">Your Email</label>
      <input type="email" name="email" id="waitlist_email_v2" required placeholder="Your email address" class="w-full px-4 py-4 rounded-xl border border-v2-outline-variant bg-v2-surface-container-lowest text-v2-on-surface focus:outline-none focus:ring-2 focus:ring-v2-primary/50 focus:border-v2-primary transition-all" />
    </div>
    <div class="flex-1">
      <label for="partner_email_v2" class="sr-only">Partner's Email</label>
      <input type="email" name="partner_email" id="partner_email_v2" placeholder="Partner's email (optional)" class="w-full px-4 py-4 rounded-xl border border-v2-outline-variant bg-v2-surface-container-lowest text-v2-on-surface focus:outline-none focus:ring-2 focus:ring-v2-primary/50 focus:border-v2-primary transition-all" />
    </div>
  </div>

  <div>
    <label for="goal_v2" class="sr-only">Primary Goal</label>
    <select name="primary_goal" id="goal_v2" required class="w-full px-4 py-4 rounded-xl border border-v2-outline-variant bg-v2-surface-container-lowest text-v2-on-surface-variant focus:outline-none focus:ring-2 focus:ring-v2-primary/50 focus:border-v2-primary transition-all appearance-none">
      <option value="" disabled selected>What is your shared primary goal?</option>
      <option value="Stop arguing about dinner">Stop arguing about "what's for dinner"</option>
      <option value="Different portion/diet goals">Eat the same meals but with different portion goals</option>
      <option value="Reduce food waste">Reduce food waste and save money</option>
      <option value="Just want dinner easier">We just want dinner to be easier (no specific diet goals)</option>
    </select>
  </div>

  <button type="submit" class="w-full bg-v2-primary hover:bg-v2-primary/90 text-v2-on-primary font-semibold text-lg py-4 rounded-xl transition-colors mt-2 shadow-sm">
    Join Free Beta Waitlist
  </button>
</form>

---
import features from '../../data/v2/features.json';

interface Props {
  title?: string;
  showLink?: boolean;
}

const { title = 'Two ways to cook. One shared kitchen.', showLink = true } = Astro.props;
---

<section class="py-24 max-w-6xl mx-auto px-6">
  <div class="text-center mb-16">
    <h2 class="text-3xl md:text-4xl font-semibold mb-4 tracking-tight text-v2-on-surface">{title}</h2>
    <p class="text-xl text-v2-on-surface-variant max-w-2xl mx-auto">V2 gives you full agency over your dinner decisions. Cook from your pantry or browse what you're craving — both paths lead to the same adaptive cooking experience.</p>
  </div>
  
  <!-- Bento grid layout -->
  <div class="grid md:grid-cols-2 gap-6">
    {features.features.map((feature, index) => (
      <a
        href={showLink ? feature.href : undefined}
        class={`block group rounded-3xl p-8 transition-all border ${
          feature.badge
            ? 'md:col-span-2 bg-v2-surface-container border-v2-outline-variant hover:border-v2-primary hover:shadow-md'
            : 'bg-v2-surface-container-low border-v2-outline-variant hover:border-v2-primary hover:shadow-md'
        }`}
      >
        <div class="bg-v2-surface-container-lowest w-14 h-14 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-v2-primary/10 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7 text-v2-primary">
            {feature.icon === 'toggle' && <><rect x="1" y="5" width="22" height="14" rx="7"/><circle cx="16" cy="12" r="3"/></>}
            {feature.icon === 'utensils' && <><path d="m2.5 1.5-1 2.5 2 1 3-1 1-2.5-2-1z"/><path d="m19.5 4.5-1 2.5 2 1 3-1 1-2.5-2-1z"/><path d="M5 3v18a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3"/><path d="M5 12h14"/></>}
            {feature.icon === 'refresh-cw' && <><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></>}
            {feature.icon === 'carrot' && <><path d="M2.3 11.7c.4-.4.9-.7 1.4-.7 2.3 0 4.3 1 5.8 2.5L16 20l3-3-6.5-6.5c-1.5-1.5-2.5-3.5-2.5-5.8 0-.5.3-1 .7-1.4"/><path d="M15 5l4 4"/><path d="M19 9l-1.5 1.5"/><path d="M17 11l1.5 1.5"/></>}
          </svg>
        </div>
        <h3 class="text-2xl font-semibold mb-3 tracking-tight flex items-center gap-3 text-v2-on-surface">
          {feature.title}
          {feature.badge && (
            <span class="bg-v2-primary/10 text-v2-primary text-xs px-2 py-1 rounded-full uppercase tracking-wider font-semibold">
              {feature.badge}
            </span>
          )}
        </h3>
        <p class="text-v2-on-surface-variant leading-relaxed text-lg">{feature.shortDescription}</p>
        {showLink && (
          <span class="inline-flex items-center gap-1 text-v2-primary font-medium mt-4 group-hover:gap-2 transition-all">
            Learn more <span>&rarr;</span>
          </span>
        )}
        {feature.badge && feature.example?.cookNow && (
          <div class="mt-6 grid md:grid-cols-2 gap-4">
            <div class="bg-v2-surface-container-lowest rounded-2xl p-4 border border-v2-outline-variant">
              <p class="text-sm font-semibold text-v2-primary mb-1">{feature.example.cookNow.label}</p>
              <p class="text-sm text-v2-on-surface-variant">{feature.example.cookNow.meals}</p>
              <span class="inline-block mt-2 text-xs bg-v2-primary/10 text-v2-primary px-2 py-0.5 rounded-full">{feature.example.cookNow.badge}</span>
            </div>
            <div class="bg-v2-surface-container-lowest rounded-2xl p-4 border border-v2-outline-variant">
              <p class="text-sm font-semibold text-v2-primary mb-1">{feature.example.iWantThis.label}</p>
              <p class="text-sm text-v2-on-surface-variant">{feature.example.iWantThis.meals}</p>
              <span class="inline-block mt-2 text-xs bg-v2-secondary-container/30 text-v2-on-secondary-container px-2 py-0.5 rounded-full">{feature.example.iWantThis.badge}</span>
            </div>
          </div>
        )}
      </a>
    ))}
  </div>
</section>

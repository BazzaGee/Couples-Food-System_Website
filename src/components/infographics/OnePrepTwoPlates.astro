---
interface Props {
  version?: 'v1' | 'v2';
}

const { version = 'v1' } = Astro.props;
const isV2 = version === 'v2';
const primaryColor = isV2 ? 'text-v2-primary' : 'text-sage';
const primaryBg = isV2 ? 'bg-v2-primary' : 'bg-sage';
const primaryLight = isV2 ? 'bg-v2-primary/10' : 'bg-sage/10';
const partnerAColor = isV2 ? 'border-v2-primary' : 'border-sage';
const partnerBColor = isV2 ? 'border-v2-secondary' : 'border-terracotta';
const partnerAName = isV2 ? 'text-v2-primary' : 'text-sage-dark';
const partnerBName = isV2 ? 'text-v2-secondary' : 'text-terracotta-dark';
const surfaceBg = isV2 ? 'bg-v2-surface-container-lowest' : 'bg-white';
const surfaceBorder = isV2 ? 'border-v2-outline-variant' : 'border-border';
const textColor = isV2 ? 'text-v2-on-surface' : 'text-text-primary';
const textSecondary = isV2 ? 'text-v2-on-surface-variant' : 'text-text-secondary';
---

<section class="py-16 md:py-24 max-w-5xl mx-auto px-6">
  <div class="text-center mb-12">
    <h2 class={`text-3xl md:text-4xl font-semibold tracking-tight mb-4 ${textColor}`}>
      One Meal. Two Plates. Both Perfect.
    </h2>
    <p class={`text-lg md:text-xl ${textSecondary} max-w-2xl mx-auto`}>
      Cook one meal together in a single pan. The AI gives each partner their own plating instructions — different portions, different macros, same delicious dinner.
    </p>
  </div>

  <!-- Visual Diagram -->
  <div class={`${surfaceBg} rounded-3xl border ${surfaceBorder} p-8 md:p-12 shadow-sm`}>
    <!-- Top: The Shared Pan -->
    <div class="text-center mb-8">
      <div class={`inline-flex items-center gap-3 ${primaryLight} px-6 py-4 rounded-2xl border ${surfaceBorder}`}>
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={primaryColor}>
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
          <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
          <path d="M9 9h.01"/>
          <path d="M15 9h.01"/>
        </svg>
        <div class="text-left">
          <p class={`font-semibold ${textColor}`}>Chicken Stir-Fry</p>
          <p class={`text-sm ${textSecondary}`}>One recipe. One pan. Cooked together.</p>
        </div>
      </div>
    </div>

    <!-- Arrow Split -->
    <div class="flex justify-center mb-8">
      <div class="flex items-center gap-4">
        <div class={`w-16 h-0.5 ${isV2 ? 'bg-v2-primary' : 'bg-sage'} rotate-[-20deg]`}></div>
        <div class={`w-3 h-3 rounded-full ${primaryBg}`}></div>
        <div class={`w-16 h-0.5 ${isV2 ? 'bg-v2-primary' : 'bg-sage'} rotate-[20deg]`}></div>
      </div>
    </div>

    <!-- Two Plates -->
    <div class="grid md:grid-cols-2 gap-6 md:gap-8">
      <!-- Partner A Plate -->
      <div class={`${surfaceBg} rounded-2xl border-2 ${partnerAColor} p-6 relative`}>
        <div class={`absolute -top-3 left-6 ${isV2 ? 'bg-v2-primary' : 'bg-sage'} text-white text-xs font-semibold px-3 py-1 rounded-full`}>
          Partner A
        </div>
        <div class="mt-4">
          <div class="flex items-center gap-2 mb-3">
            <span class={`text-sm font-semibold ${partnerAName}`}>Weight Loss</span>
            <span class={`text-xs ${textSecondary}`}>~450 cal</span>
          </div>
          <div class={`space-y-2 ${textSecondary} text-sm`}>
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class={primaryColor}><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
              <span>4oz chicken breast</span>
            </div>
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class={primaryColor}><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
              <span>Bed of spinach</span>
            </div>
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class={primaryColor}><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
              <span>½ cup rice</span>
            </div>
          </div>
          <div class={`mt-4 pt-4 border-t ${surfaceBorder} grid grid-cols-3 gap-2 text-center`}>
            <div>
              <p class={`text-lg font-bold ${partnerAName}`}>35g</p>
              <p class={`text-xs ${textSecondary}`}>Protein</p>
            </div>
            <div>
              <p class={`text-lg font-bold ${partnerAName}`}>40g</p>
              <p class={`text-xs ${textSecondary}`}>Carbs</p>
            </div>
            <div>
              <p class={`text-lg font-bold ${partnerAName}`}>12g</p>
              <p class={`text-xs ${textSecondary}`}>Fat</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Partner B Plate -->
      <div class={`${surfaceBg} rounded-2xl border-2 ${partnerBColor} p-6 relative`}>
        <div class={`absolute -top-3 left-6 ${isV2 ? 'bg-v2-secondary' : 'bg-terracotta'} text-white text-xs font-semibold px-3 py-1 rounded-full`}>
          Partner B
        </div>
        <div class="mt-4">
          <div class="flex items-center gap-2 mb-3">
            <span class={`text-sm font-semibold ${partnerBName}`}>Muscle Gain</span>
            <span class={`text-xs ${textSecondary}`}>~700 cal</span>
          </div>
          <div class={`space-y-2 ${textSecondary} text-sm`}>
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class={partnerBName}><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
              <span>6oz chicken breast</span>
            </div>
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class={partnerBName}><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
              <span>Full cup rice</span>
            </div>
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class={partnerBName}><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
              <span>Side of vegetables</span>
            </div>
          </div>
          <div class={`mt-4 pt-4 border-t ${surfaceBorder} grid grid-cols-3 gap-2 text-center`}>
            <div>
              <p class={`text-lg font-bold ${partnerBName}`}>52g</p>
              <p class={`text-xs ${textSecondary}`}>Protein</p>
            </div>
            <div>
              <p class={`text-lg font-bold ${partnerBName}`}>75g</p>
              <p class={`text-xs ${textSecondary}`}>Carbs</p>
            </div>
            <div>
              <p class={`text-lg font-bold ${partnerBName}`}>15g</p>
              <p class={`text-xs ${textSecondary}`}>Fat</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Tagline -->
    <div class="text-center mt-8">
      <p class={`text-lg font-semibold ${primaryColor} ${isV2 ? 'bg-v2-primary/5' : 'bg-sage/5'} inline-block px-6 py-3 rounded-xl`}>
        Same stir-fry. Same pan. Different plates. Zero arguments.
      </p>
    </div>
  </div>
</section>
